    <mathematical_framework id="fmo">
        <name>FMO: Fock Matrix Optimization</name>
        <theoretical_foundation>
            <concept>Quantum-inspired optimization using Fock operator formalism</concept>
            <origin>Adapted from quantum chemistry Hartree-Fock methods</origin>
        </theoretical_foundation>
        
        <core_mathematics>
            <fock_operator>
                <definition>
                    <latex>\hat{F} = \hat{h} + \sum_j (2\hat{J}_j - \hat{K}_j)</latex>
                    <components>
                        <component name="h" description="One-electron Hamiltonian"/>
                        <component name="J" description="Coulomb operator"/>
                        <component name="K" description="Exchange operator"/>
                    </components>
                </definition>
                
                <eigenvalue_problem>
                    <latex>\hat{F}|\psi_i\rangle = \epsilon_i|\psi_i\rangle</latex>
                    <description>Self-consistent field equations</description>
                </eigenvalue_problem>
            </fock_operator>
            
            <optimization_scheme>
                <scf_iteration>
                    <steps>
                        <step>Construct Fock matrix from current state</step>
                        <step>Diagonalize to find eigenstates</step>
                        <step>Update state based on lowest eigenvalues</step>
                        <step>Check convergence criteria</step>
                    </steps>
                </scf_iteration>
                
                <convergence_criteria>
                    <energy_threshold>1e-6</energy_threshold>
                    <density_threshold>1e-8</density_threshold>
                </convergence_criteria>
            </optimization_scheme>
        </core_mathematics>
    </mathematical_framework>
    
